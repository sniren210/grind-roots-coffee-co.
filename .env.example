# ─────────────────────────────────────────────────────────────────────────────
# Environment variables for grind-roots-coffee deployment
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# Docker Hub / Registry credentials
# Required for: docker login
DOCKER_USER=your-dockerhub-username
DOCKER_TOKEN=your-dockerhub-access-token

# Registry to push the image to
# Examples:
#   docker.io       — Docker Hub
#   ghcr.io         — GitHub Container Registry
#   registry.example.com  — Self-hosted or custom registry
REGISTRY=docker.io

# Image name on the registry
# For Docker Hub: username/repo-name
# For GHCR: ghcr.io/username/repo-name
IMAGE=username/grind-roots-coffee

# Image tag — use "latest" for production, or a date/semver for versioning
# Leave blank to auto-generate a timestamped tag
TAG=latest

# ─── VPS ─────────────────────────────────────────────────────────────────────
# SSH host for your VPS
# Format: user@ip-or-hostname
VPS_HOST=root@198.51.100.42

# Path on VPS where the app lives
VPS_DIR=/opt/grind-roots

# Port the app runs on inside the container
PORT=3000

# ─── Optional ─────────────────────────────────────────────────────────────────
# REGISTRY_USER=username
# REGISTRY_TOKEN=password
